# Database Configuration (Used by Docker Compose and Prisma)
DB_USER=your_db_username_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here
DATABASE_URL=postgresql://your_db_username_here:your_db_password_here@postgres-db:5432/your_db_name_here?schema=public

# Security Secrets (Must be changed in production)
JWT_SECRET=your_jwt_signing_secret_here
QR_SECRET=your_qr_token_signing_secret_here

# Port Configuration
PORT=5000
